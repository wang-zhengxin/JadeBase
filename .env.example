# Public port exposed by the frontend reverse proxy
APP_PORT=8080

# OpenAI-compatible chat model (DeepSeek example)
MODEL_BASE_URL=https://api.deepseek.com
MODEL_API_KEY=
CHAT_MODEL=deepseek-chat

# Embeddings can use a different provider, such as DashScope compatible mode.
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=384

# Optional BGE/Qwen-compatible rerank endpoint
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=bge-reranker-v2-m3

DB_URL=jdbc:postgresql://postgres:5432/jadebase
DB_USERNAME=jadebase
DB_PASSWORD=jadebase

# Set to true when JadeBase is served over HTTPS.
AUTH_SECURE_COOKIE=false

# Encrypts connector credentials at rest. Set a long, stable, deployment-specific value.
CONNECTOR_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Default interval for Feishu incremental scans.
FEISHU_SYNC_INTERVAL_MINUTES=15
